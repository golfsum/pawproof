# Copy this file to `.env` and fill in real values. All vars prefixed with
# EXPO_PUBLIC_ are inlined into the JS bundle and readable by the client app.

# --- Firebase Web SDK config (Project settings -> Your apps -> Web app) ---
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abcdef0123456789

# --- OCR ---
# OCR now runs through the server proxy at <web>/api/ocr, which holds the
# Gemini key server-side and rate-limits per user. The mobile app no longer
# needs a Gemini key. (Set GEMINI_API_KEY on the web/Vercel side instead.)

# --- Google Sign-In ---
# From the Google Cloud OAuth client created automatically when you enable the
# Google sign-in provider in Firebase. You need the iOS client ID for native
# iOS sign-in, and the Web client ID is what Firebase issues ID tokens against.
# Pull them from console.cloud.google.com → APIs & Services → Credentials.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=000000000000-abcdef.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=000000000000-abcdef.apps.googleusercontent.com

# Also: paste the REVERSED iOS client ID (e.g. com.googleusercontent.apps.000000-abcdef)
# into app.json → plugins → @react-native-google-signin/google-signin → iosUrlScheme.

# Optional: override the API base for OCR proxy during local dev
# (defaults to https://pawproof.app). e.g. http://192.168.1.50:3000
# EXPO_PUBLIC_API_BASE_URL=

# --- RevenueCat (in-app purchases) ---
# Public iOS SDK key from RevenueCat dashboard (safe in client). Without it,
# billing is disabled and the paywall falls back to dev mode.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxx

# --- Weekly SEO MCP (server-side/local automation only) ---
# DataForSEO API credentials. These endpoints are paid; never expose them to clients.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Optional Zapier, Make, or first-party webhook for article syndication.
SEO_SYNDICATION_WEBHOOK_URL=
