# Firebase Web SDK. Same project as the mobile app so users see one
# account across mobile + web. Pull these from the Firebase console
# (Project settings → General → Your apps → Web app).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK, server-only. Paste the full service account JSON
# as a single-line string (escape internal newlines in private_key as \n).
# Generate at Firebase console → Project settings → Service accounts →
# Generate new private key.
FIREBASE_ADMIN_SA_JSON=

# Comma-separated Firebase UIDs that should see the /admin dashboard.
# Source of truth. Never read from the client, always verified
# server-side by requireAdmin().
ADMIN_UIDS=

# Resend (transactional email). Used by the contact form + ticket reply
# notifications. Sign up at resend.com, verify pawproof.app domain.
RESEND_API_KEY=
RESEND_FROM_EMAIL=support@pawproof.app

# Public site URL, used in email links and OpenGraph tags.
NEXT_PUBLIC_SITE_URL=https://pawproof.app

# --- Gemini OCR (server-side proxy at /api/ocr) ---
# Server-only Gemini key. NOT prefixed NEXT_PUBLIC, so it never reaches the client.
# Get from Google AI Studio. Set a budget/quota cap in Google Cloud as a backstop.
GEMINI_API_KEY=your-server-side-gemini-key

# --- Page-view analytics (/api/track) ---
# Comma-separated IPs to EXCLUDE from page-view counts (your own/office/dev IPs)
# so they don't inflate the numbers shown in the admin overview. Optional.
ANALYTICS_EXCLUDE_IPS=203.0.113.5,198.51.100.22
