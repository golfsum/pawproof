{
  "expo": {
    "name": "PawProof",
    "slug": "pawproof",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "pawproof",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF1DD"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pawproof.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "PawProof uses the camera so you can scan vaccine records and take photos of your pets.",
        "NSPhotoLibraryUsageDescription": "PawProof needs access to your photos so you can attach pictures of your pets, their documents, and journal entries.",
        "NSPhotoLibraryAddUsageDescription": "PawProof saves exported pet health summaries to your photo library when you ask.",
        "NSUserNotificationsUsageDescription": "PawProof sends reminders for feeding, walks, medications, and vaccine expirations.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.pawproof.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FAF7F2"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "PawProof needs access to your photos so you can attach pictures of your pets and their documents.",
          "cameraPermission": "PawProof uses the camera so you can scan vaccine records and take photos of your pets."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2A8FA8"
        }
      ],
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.113400450786-pqvjstkj19u0beb9582mngmcktvj1stt"
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "2a49e32a-c44b-4280-b17f-20a2de25cb26"
      },
      "firebase": {
        "apiKey": "AIzaSyAjUwgJm28jODhyz6WlK-F6EnW9AsXlhpI",
        "authDomain": "pawproof-ab9de.firebaseapp.com",
        "projectId": "pawproof-ab9de",
        "storageBucket": "pawproof-ab9de.firebasestorage.app",
        "messagingSenderId": "157335586328",
        "appId": "1:157335586328:web:47e7a1d7eafd3d7f65256d"
      }
    }
  }
}
