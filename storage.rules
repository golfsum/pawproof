rules_version = '2';

// PawProof Cloud Storage rules.
// Uploads are written to `<prefix>/<uid>/<timestamp>.jpg` where prefix is
// "pets" or "documents" (see src/lib/storage.ts). Scope every object to its
// owning user. Default-deny anything that doesn't match.
service firebase.storage {
  match /b/{bucket}/o {

    // Pet photos and scanned documents live at users/<uid>/<folder>/<file>
    // (see src/lib/storage.ts). Only the owner may read/write.
    match /users/{uid}/{folder}/{fileName} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid)
        && request.resource.size < 15 * 1024 * 1024            // 15 MB cap
        && request.resource.contentType.matches('image/.*|application/pdf');
      allow delete: if isOwner(uid);
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }
  }
}
